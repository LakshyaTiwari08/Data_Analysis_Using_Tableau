      <aliases enabled='yes' />
      <column caption='Weekend Remarks' datatype='string' name='[Calculation_1792432666114990080]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;weekday&apos;,[Order Date]) = 1&#13;&#10;OR DATEPART(&apos;weekday&apos;,[Order Date]) = 7&#13;&#10;THEN &quot;Weekend&quot;&#13;&#10;ELSE &quot;Weekday&quot;&#13;&#10;END' />
      </column>
      <column caption='Weekday Name' datatype='string' name='[Calculation_1792432666116562945]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;,[Order Date])' />
      </column>
      <column caption='average sales' datatype='real' name='[Calculation_1792432666116993026]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(Sales)' />
      </column>
      <column caption='YEAR' datatype='integer' datatype-customized='true' name='[Calculation_226305895318970368]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Order Date])' />
      </column>
      <column aggregation='Sum' caption='QUATER' datatype='integer' name='[Calculation_226305895319736321]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;quarter&apos;, [Order Date])' />
      </column>
      <column aggregation='Sum' caption='MONTH' datatype='integer' name='[Calculation_226305895320645634]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MONTH([Order Date])' />
      </column>
      <column aggregation='Sum' caption='DAY' datatype='integer' name='[Calculation_226305895320821763]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DAY([Order Date])' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_226305895322406916]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit]/[Sales]' />
      </column>
      <column caption='Delivery Dates ' datatype='integer' name='[Calculation_226305895322550277]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date])' />
